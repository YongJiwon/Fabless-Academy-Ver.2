#include <stdio.h>
#include "platform.h"
#include "xparameters.h"
#include "sleep.h"
#include <stdint.h>


#define GPIOA_BASEADDR XPAR_LED_F_0_S00_AXI_BASEADDR
#define GPIOA_CR		(*(uint32_t *) (GPIOA_BASEADDR + 0x00))
#define GPIOA_IDR		(*(uint32_t *) (GPIOA_BASEADDR + 0x04))
#define GPIOA_ODR		(*(uint32_t *) (GPIOA_BASEADDR + 0x08))

int main()
{
    init_platform();

    GPIOA_CR = 0xFFFF;
    GPIOA_ODR = 0x0000;

    uint32_t led = 0x0001;
    int dir = 1;

    while (1)
    {
        GPIOA_ODR = led;

        if (dir)
        {
            //led = ((led << 1) | 1) & 0xFFFF;
        	led <<= 1 ;
            if (led == 0x8000)
                dir = 0;
        }
        else
        {
            led >>= 1;

            if (led == 0x0000)
            {
                GPIOA_ODR = 0x0000;
                usleep(100000);

                led = 0x0001;
                dir = 1;
            }
        }
        	if(dir ==1 && GPIOA_ODR != 0x0000) usleep(100000);
    }

    cleanup_platform();
    return 0;
}
