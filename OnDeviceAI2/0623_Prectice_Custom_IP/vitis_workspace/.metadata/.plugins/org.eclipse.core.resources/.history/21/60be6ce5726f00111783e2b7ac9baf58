#include "sleep.h"
#include "driver/LED/LED.h"
#include "xil_printf.h"


#define FND_DATA_GPIO	GPIOA
#define FND_COM_GPIO	GPIOB


void FND_Init()
{
	uint32_t fndComTemp = GPIO_GetCR(GPIOB);
	fndComTemp |= 0x0f;
	GPIO_SetMode(GPIOB, fndComTemp);

	GPIO_SetMode(GPIOA, 0xff);
}


int main()
{
	int counter = 0;
	uint16_t ledState =1;

	LED_Init();
	FND_Init();

	while(1)
	{
		xil_printf("counter = %d\n", counter++);
		ledState = (ledState >> 1) | (ledState << 15);
		LED_WritePort16(ledState);

		usleep(100000);
	}


	return 0;

}


