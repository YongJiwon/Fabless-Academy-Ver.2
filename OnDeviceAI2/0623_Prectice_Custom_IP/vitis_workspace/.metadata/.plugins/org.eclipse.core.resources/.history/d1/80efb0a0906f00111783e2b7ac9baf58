typedef enum {
	NO_ACT = 0,
	ACT_PUSHED,
	ACT_RELEASED
} button_status_e;

typedef enum {
	RELEASED = 0,
	PUSHED
} button_state_e;

typedef struct {

	GPIO_TypeDef *GPIOx;
	uint32_t gpio_pin;
	button_state_e prevState;
} hbutton;

hbutton btnRunStop, btnClear;



void Button_Init()
{
	uint32_t btnPort = GPIO_GetCR(GPIOB);
	btnPort &= ~( 1<<4 | 1<<5 ); //4번 5번만 0
	GPIO_SetMode(GPIOB,btnPort);
	Button_SetInit(&hbtnRunStop, GPIOB, GPIO_PIN_4);
	Button_SetInit(&hbtnClear, GPIOB, GPIO_PIN_5);
}

void Button_SetInit(hbutton *hbtn, GPIO_TypeDef *GPIO, uint32_t gpio_pin)
{
	hbtn->GPIOx = GPIOx;
	hbtn->gpio_pin = gpio_pin;
	hbtn->prevState = RELEASED;

}


button_status_e Button_GetState(hbutton *hbtn)
{
	//static button_state_e prevState = RELEASED;
	button_state_e curState = GPIO_ReadPin(hbtn->GPIOx,hbtn->gpio_pin) ? PUSHED:RELEASED;

	if(prevState == RELEASED  && curState == PUSHED){
		hbtn->prevState = curState;
		delay_ms(5); //debouncing
		return ACT_PUSHED;
	}
	else if(prevState == PUSHED  && curState == RELEASED){
		hbtn->prevState = curState;
		delay_ms(5); //debouncing
		return ACT_RELEASED;
	}
	return NO_ACT;
}

button_status_e Button_GetState2()
{
	static button_state_e prevState = RELEASED;
	button_state_e curState = GPIO_ReadPin(GPIOB, GPIO_PIN_5) ? PUSHED:RELEASED;

	if(prevState == RELEASED  && curState == PUSHED){
		prevState = curState;
		delay_ms(5); //debouncing
		return ACT_PUSHED;
	}
	else if(prevState == PUSHED  && curState == RELEASED){
		prevState = curState;
		delay_ms(5); //debouncing
		return ACT_RELEASED;
	}
	return NO_ACT;
}


