#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xparameters.h"
#include "sleep.h"
#include <stdint.h>

#define GPIOA_BASEADDR XPAR_GPIO_0_S00_AXI_BASEADDR
#define GPIOA_CR		(*(uint32_t *) (GPIOA_BASEADDR + 0x00))
#define GPIOA_IDR		(*(uint32_t *) (GPIOA_BASEADDR + 0x04))
#define GPIOA_ODR		(*(uint32_t *) (GPIOA_BASEADDR + 0x08))




int main()
{
	GPIOA_CR = 0xff;
    init_platform();

    cleanup_platform();

    while(1)
    {
    	GPIOA_ODR = 0x00;
    	usleep(200000);
    	if(!GPIOA_ODR == 0xff){

    		GPIOA_ODR += 0x04;
    		usleep(200000);
    	}
    	if(!GPIOA_ODR == 0x00){

    	    GPIOA_ODR -= 0x04;
    	    usleep(200000);
    	}
    }



    return 0;
}

