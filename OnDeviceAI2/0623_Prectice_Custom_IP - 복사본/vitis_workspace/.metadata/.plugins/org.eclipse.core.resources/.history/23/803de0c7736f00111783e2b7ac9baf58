#include "sleep.h"
#include "driver/LED/LED.h"
#include "xil_printf.h"


#define FND_DATA_GPIO	GPIOA
#define FND_COM_GPIO	GPIOB


void FND_Init()
{
	uint32_t fndComTemp = GPIO_GetCR(GPIOB);
	fndComTemp |= 0x0f;
	GPIO_SetMode(GPIOB, fndComTemp);

	GPIO_SetMode(GPIOA, 0xff);
}




void FND_DispDigit(uint32_t num)
{

	uint8_t fndFont[16] = {0xc0, 0xf9, 0xa4, 0xb0, 0x99, 0x92, 0x82, 0xf8,
	                       0x80, 0x90, 0x88, 0x83, 0xc6, 0xa1, 0x86, 0x8e};

	GPIO_WritePort(FND_DATA_GPIO, fndFont[num%10]);

}

int main()
{
	int counter = 0;
	uint16_t ledState =1;

	LED_Init();
	FND_Init();

	while(1)
	{
		xil_printf("counter = %d\n", counter++);
		ledState = (ledState >> 1) | (ledState << 15);
		LED_WritePort16(ledState);

		usleep(100000);
	}


	return 0;

}


