
#include "xil_printf.h"
#include "driver/LED/LED.h"
#include "driver/FND/FND.h"
#include "common/delay/delay.h"




int main()
{
	int counter = 0;
	uint16_t ledState =1;

	LED_Init();
	FND_Init();

	while(1)
	{
		xil_printf("counter = %d\n", counter++);
		ledState = (ledState >> 1) | (ledState << 15);
		LED_WritePort16(ledState);

		FND_SetNum(1234);
		/*****************************************************/
		FND_Excute();
		incTick();
		delays_ms(1);
	}


	return 0;

}



