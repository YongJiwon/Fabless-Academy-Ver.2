button_status_e Button_GetState()
{
	static button_state_e prevState = RELEASED;
	button_state_e curState = GPIO_ReadPin(GPIOB, GPIO_PIN_4) ? PUSHED:RELEASED;

	if(prevState == RELEASED  && curState == PUSHED){
		prevState = curState;
		delay_ms(5); //debouncing
		return ACT_PUSHED;
	}
	else if(prevState == PUSHED  && curState == RELEASED){
		prevState = curState;
		delay_ms(5); //debouncing
		return ACT_RELEASED;
	}
	return NO_ACT;
}

button_status_e Button_GetState2()
{
	static button_state_e prevState = RELEASED;
	button_state_e curState = GPIO_ReadPin(GPIOB, GPIO_PIN_5) ? PUSHED:RELEASED;

	if(prevState == RELEASED  && curState == PUSHED){
		prevState = curState;
		delay_ms(5); //debouncing
		return ACT_PUSHED;
	}
	else if(prevState == PUSHED  && curState == RELEASED){
		prevState = curState;
		delay_ms(5); //debouncing
		return ACT_RELEASED;
	}
	return NO_ACT;
}


